# Nessus Intelligence — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── REQUIRED ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ENVIRONMENT=development

# ── DATABASE ──────────────────────────────────────────────
# SQLite (default for MVP — zero setup)
DATABASE_URL=sqlite+aiosqlite:///./polaris.db

# PostgreSQL / Supabase (production — see SUPABASE_SETUP.md)
# Use the Supabase *Session pooler* string (port 5432), prefixed with the async driver:
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── STORAGE ───────────────────────────────────────────────
REPORT_STORAGE_PATH=./reports

# ── DATA SOURCE BASE URLS ─────────────────────────────────
OCL_BASE_URL=https://lobbycanada.gc.ca
OCL_OPEN_DATA_URL=https://open.canada.ca/data/en/dataset/432527ab-7aac-45b5-81d6-7597107a7013
ELECTIONS_CANADA_BASE_URL=https://www.elections.ca
CONTRACTS_BASE_URL=https://search.open.canada.ca
HANSARD_BASE_URL=https://www.ourcommons.ca
LEGISINFO_BASE_URL=https://www.parl.ca/LegisInfo
SEDAR_BASE_URL=https://www.sedarplus.ca

# ── CLAUDE MODEL ──────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ── REPORT SETTINGS ───────────────────────────────────────
REPORT_DELIVERY_BASE_URL=http://localhost:3000
MAX_PIPELINE_TIMEOUT_SECONDS=3600   # 1 hour hard limit (well within 24hr SLA)

# ── RATE LIMITING ─────────────────────────────────────────
SCRAPER_DELAY_SECONDS=1.0           # polite delay between requests
SCRAPER_MAX_RETRIES=3
